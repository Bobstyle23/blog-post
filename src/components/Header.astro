---
import { SITE_TITLE, GITHUB_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { IoLogoGithub } from 'react-icons/io5';
import { MdComputer } from 'react-icons/md';
import ThemeToggle from "./ThemeToggleButton"
import DropdownMenu from "./DropdownMenu"


const allPosts = Object.values(import.meta.glob('../pages/posts/*.md', {eager: true}))
const allTags = new Set<string>()
allPosts.map(post => {
  post.frontmatter.tags &&
    post.frontmatter.tags.map((tag: string) => allTags.add(tag))
})
---

<header class="fixed z-20 w-full p-2 backdrop-blur-md">
  <div class="mx-auto max-w-3xl">
    <nav class="flex items-center gap-3 text-base">
      <a href="/" class="group">
        <h2
          class="font-mplus inline-flex items-center gap-4 p-2 text-lg font-semibold tracking-tighter"
        >
          <MdComputer />Mukhammad Bobur
        </h2>
      </a>

      <div class="hidden items-center gap-6 md:flex">
        <HeaderLink href={GITHUB_URL}><IoLogoGithub />Source</HeaderLink>
      </div>
      <div class="flex-1"></div>
      <ThemeToggle client:visible />
      <DropdownMenu client:visible tags={Array.from(allTags)}/>
    </nav>
  </div>
</header>
