---
import { Image } from 'astro:assets';
---

<section>
  <h2
    class="font-mplus font-bold text-xl my-4 underline underline-offset-4 decoration-zinc-400 dark:decoration-zinc-700 decoration-4"
  >
    Created with
  </h2>
  <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <li class="text-center mb-4">
      <a href="https://www.lazyvim.org/">
        <div class="aspect-video overflow-hidden rounded-xl border border-slate-300 dark:border-zinc-700">
          <Image
          src="/lazyvim.png"
          width={1200}
          height={675}
          alt="LazyVim banner"
        />
          </div>

        <div class="mt-3 text-xl">LazyVim</div>
        <div class="opacity-70">Customized Neovim setup for coding</div>
      </a>
    </li>
    <li class="text-center mb-4">
      <a href="https://homepage-silk-chi.vercel.app/" target="_blank">
      <div  class="aspect-video overflow-hidden rounded-xl border border-slate-300 dark:border-zinc-700">
        <Image
          src="/byme.jpeg"
          width={1200}
          height={675}
          alt="MukhammadBobur Pakhriev"
        />
      </div>

        <div class="mt-3 text-xl">Me</div>
        <div class="opacity-70">
          MukhammadBobur - Frontend Enginner
        </div>
      </a>
    </li>
    <li class="text-center mb-4">
      <a href="https://astro.build/" class="w-full">

          <Image
          class="border border-slate-300 dark:border-zinc-700 rounded-xl"
          src="/astrojs.jpg"
          width={1440}
          height={720}
          alt="AstroJS banner"
          />

        <div class="mt-3 text-xl">Astro</div>
        <div class="opacity-70">
          Framework for building fast static websites
        </div>
      </a>
    </li>


  </ul>
</section>
